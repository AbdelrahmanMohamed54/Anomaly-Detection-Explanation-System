          "method": "GET",
          "queryParams": "",
          "refId": "A",
          "urlPath": "/history"
        }
      ],
      "title": "Escalation Required",
      "transformations": [
        {
          "id": "convertFieldType",
          "options": {
            "conversions": [{ "destinationType": "number", "targetField": "Escalation Required" }],
            "fields": {}
          }
        },
        {
          "id": "reduce",
          "options": {
            "reducers": ["sum"]
          }
        }
      ],
      "type": "stat"
    },
    {
      "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_ANOMALY_API}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
