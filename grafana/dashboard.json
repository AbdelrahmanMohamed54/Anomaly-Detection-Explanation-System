      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 9 },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["sum"], "fields": "/^Escalation Required$/", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "marcusolsson-json-datasource", "uid": "${DS_ANOMALY_API}" },
